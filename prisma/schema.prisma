// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Report {
  id        String   @id @default(cuid())
  markdown  String
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([expiresAt])
}
